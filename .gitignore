cat > .gitignore <<'EOF'
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

# macOS
.DS_Store

# Local exports
data_exports/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Environment / secrets
.env

# IDE
.vscode/
.idea/

# Logs
*.log

# Keep these local only
docs/interview_notes.md
docs/progress_log.md
EOF